# === Локальная разработка ===
# URL бэкенда (по умолчанию localhost:3001)
VITE_API_URL=http://localhost:3001/api

# === Продакшен (Vercel) ===
# Вариант 1 — Proxy (рекомендуется): оставьте VITE_API_URL пустым,
# задайте только VERCEL_BACKEND_URL = URL вашего backend (например https://your-app.onrender.com)
#
# Вариант 2 — Прямые вызовы: задайте VITE_API_URL = URL backend API (например https://your-app.onrender.com/api)
