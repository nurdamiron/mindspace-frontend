    "privacy": {
      "title": "Your data is safe",
      "subtitle": "We understand that mental health is personal. Confidentiality is built into every level of the platform.",
      "items": [
        {
          "title": "Only you and your psychologist",
          "desc": "Session details and your check-ins are visible only to you and the specialist you work with."
        },
        {
          "title": "Anonymous analytics",
          "desc": "Administration sees only anonymized statistics — no names or personal data."
        },
        {
          "title": "Secure storage",
          "desc": "All data is encrypted in transit and at rest. We do not share information with third parties."
        },
        {
          "title": "You are in control",
          "desc": "You can stop using the platform at any time."
        }
      ]
    },
    "faq": {
      "title": "Frequently Asked Questions",
      "items": [
        {
          "q": "Is my data confidential?",
          "a": "Yes. Your check-ins and session details are accessible only to you and your psychologist. Administration sees only anonymous faculty-level statistics."
        },
        {
          "q": "Is it free for students?",
          "a": "Yes, the platform is completely free for all university students."
        },
        {
          "q": "How do I book a psychologist?",
          "a": "Go to the Psychologists section, choose a specialist, and pick a convenient time from available slots."
        },
        {
          "q": "Can my dean or teachers see my data?",
          "a": "No. Teachers and the dean's office have no access to the platform. Only psychologists and system administrators do."
        },
        {
          "q": "Can I chat anonymously?",
          "a": "The AI assistant is available immediately after registration. Booking a psychologist requires a profile, but the specialist maintains professional confidentiality."
        }
      ]
    },
    "cta": {
      "title": "Start taking care of your mental health today",
      "subtitle": "Free for all university students",
      "button": "Register for free"
    },
