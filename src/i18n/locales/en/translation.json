    "features": {
      "title": "Everything you need for psychological well-being",
      "items": [
        { "title": "Daily monitoring", "desc": "Track your mood, stress, sleep, and energy every day. See the dynamics of your condition." },
        { "title": "Psychological screening", "desc": "Take a standardised test to assess your stress level and psychological state." },
        { "title": "Psychologist catalogue", "desc": "Choose a specialist by specialisation, language, and experience. Book a convenient time." },
        { "title": "AI assistant 24/7", "desc": "Get support at any time. The AI will listen, support you, and give basic advice." },
        { "title": "Personal analytics", "desc": "AI analyses your data and provides personal insights for improving your well-being." },
        { "title": "Confidentiality", "desc": "Your data is protected. Only you and your psychologist have access to your information." }
      ]
    },
    "steps": {
      "title": "How it works",
      "items": [
        { "title": "Register", "desc": "Create an account in 2 minutes using your university email." },
        { "title": "Track yourself", "desc": "Complete daily check-ins and take psychological screenings." },
        { "title": "Get support", "desc": "Chat with the AI assistant or book an appointment with a live psychologist." }
      ]
    },
    "roles": {
